#!/usr/bin/env Rscript

# Install CRAN packages
cat("Installing CRAN packages...\n")
install.packages(c(
  "shiny",
  "shinydashboard", 
  "shinyFiles",
  "shinyjs",
  "DT",
  "plotly",
  "arrow",
  "vroom",
  "qqman",
  "digest",
  "rmarkdown",
  "webshot2",
  "chromote",
  "remotes"
), repos = "https://cloud.r-project.org", quiet = FALSE)

# Install Bioconductor packages
cat("Installing Bioconductor packages...\n")
if (!requireNamespace("BiocManager", quietly = TRUE))
    install.packages("BiocManager")

BiocManager::install(c(
  "VariantAnnotation",
  "karyoploteR"
), update = FALSE, ask = FALSE)

# Install igvShiny from GitHub (fallback if Bioc version unavailable)
cat("Installing igvShiny from GitHub...\n")
tryCatch({
  remotes::install_github("gladkia/igvShiny", upgrade = "never", quiet = FALSE)
}, error = function(e) {
  cat("igvShiny installation failed (non-critical):", e$message, "\n")
})

cat("Package installation complete!\n")
