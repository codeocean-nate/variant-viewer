{
	"version": 1,
	"base_image": "codeocean/bioconductor-320:RELEASE_3_20_NoGPU",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"apt": {
			"packages": [
				{
					"name": "bcftools",
					"version": "1.19-1build2"
				},
				{
					"name": "chromium-browser",
					"version": "2:1snap1-0ubuntu2"
				},
				{
					"name": "openjdk-17-jre-headless",
					"version": "17.0.18+8-1~24.04.1"
				},
				{
					"name": "pandoc",
					"version": "3.8.2.1-1"
				},
				{
					"name": "samtools",
					"version": "1.19.2-1build2"
				},
				{
					"name": "shiny-server",
					"version": "1.5.20.1002-2build1"
				},
				{
					"name": "tabix",
					"version": "1.19+ds-1.1build3"
				}
			],
			"install_software_properties_common": true,
			"install_gnupg": true
		}
	}
}